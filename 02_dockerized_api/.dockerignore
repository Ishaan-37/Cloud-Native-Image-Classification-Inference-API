# .dockerignore
# Files/dirs that should NOT be copied into the Docker image.
# Keeping the image lean = faster builds and smaller size.

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environment
venv/
.venv/
env/

# Tests (not needed at runtime)
tests/

# Git
.git/
.gitignore

# Docs and markdown
*.md
FRAMEWORK_SURVEY.md

# OS files
.DS_Store
Thumbs.db

# IDE configs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Environment variable files (never bake secrets into an image!)
.env
.env.*

# Jupyter notebooks
*.ipynb
.ipynb_checkpoints/

# Logs
*.log
logs/
